{
  "name": "nexusresearch",
  "version": "0.1.0",
  "description": "NexusResearch - Desktop academic research assistant",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"tsc -p tsconfig.node.json --watch --preserveWatchOutput\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "tsc -p tsconfig.node.json && vite build",
    "pack": "tsc -p tsconfig.node.json && vite build && electron-builder --dir",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:linux": "npm run build && electron-builder --linux",
    "test": "vitest"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "katex": "^0.16.0",
    "marked": "^15.0.0",
    "pdfjs-dist": "^5.7.284",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@types/better-sqlite3": "^7.6.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.2.1",
    "electron": "^33.4.11",
    "electron-builder": "^25.0.0",
    "electron-vite": "^5.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0",
    "wait-on": "^9.0.10"
  }
}
